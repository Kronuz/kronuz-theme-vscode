{
	"name": "Kronuz",
	"type": "dark",
	"semanticHighlighting": true,
	"colors": {
		"focusBorder": "#d8996e80",
		"foreground": "#c8c6c5",
		"selection.background": "#3366ff55",
		"editor.background": "#383838",
		"editor.foreground": "#c8c6c5",
		"editorCursor.foreground": "#d08040",
		"editor.selectionBackground": "#3366ff55",
		"editor.selectionHighlightBackground": "#6ea3d822",
		"editor.wordHighlightBackground": "#6ea3d820",
		"editor.wordHighlightStrongBackground": "#9e6ed826",
		"editor.findMatchBackground": "#d8996e55",
		"editor.findMatchHighlightBackground": "#d8996e33",
		"editor.lineHighlightBackground": "#ffffff0a",
		"editor.rangeHighlightBackground": "#6ea3d814",
		"editorLineNumber.foreground": "#7a7775",
		"editorLineNumber.activeForeground": "#c8c6c5",
		"editorIndentGuide.background": "#ffffff10",
		"editorIndentGuide.activeBackground": "#d8996e66",
		"editorWhitespace.foreground": "#ffffff12",
		"editorRuler.foreground": "#ffffff0e",
		"editorBracketMatch.background": "#d8996e22",
		"editorBracketMatch.border": "#d8996e88",
		"editorError.foreground": "#d86e6e",
		"editorWarning.foreground": "#d8996e",
		"editorInfo.foreground": "#6ea3d8",
		"editorGutter.modifiedBackground": "#d8996e",
		"editorGutter.addedBackground": "#6ed8aa",
		"editorGutter.deletedBackground": "#d86e6e",
		"editorWidget.background": "#303030",
		"editorWidget.border": "#575757",
		"editorHoverWidget.background": "#303030",
		"editorHoverWidget.border": "#575757",
		"editorSuggestWidget.background": "#303030",
		"editorSuggestWidget.selectedBackground": "#333333",
		"editorGroup.border": "#242424",
		"editorGroupHeader.tabsBackground": "#2b2b2b",
		"tab.activeBackground": "#383838",
		"tab.inactiveBackground": "#2b2b2b",
		"tab.activeForeground": "#c8c6c5",
		"tab.inactiveForeground": "#9a9794",
		"tab.border": "#242424",
		"tab.activeBorderTop": "#d08040",
		"activityBar.background": "#242424",
		"activityBar.foreground": "#c8c6c5",
		"activityBar.inactiveForeground": "#7a7775",
		"activityBarBadge.background": "#6ea3d8",
		"activityBarBadge.foreground": "#ffffff",
		"sideBar.background": "#2b2b2b",
		"sideBar.foreground": "#9a9794",
		"sideBarSectionHeader.background": "#242424",
		"sideBarSectionHeader.foreground": "#c8c6c5",
		"sideBarTitle.foreground": "#c8c6c5",
		"list.activeSelectionBackground": "#333333",
		"list.activeSelectionForeground": "#c8c6c5",
		"list.inactiveSelectionBackground": "#303030",
		"list.hoverBackground": "#ffffff0c",
		"list.highlightForeground": "#d08040",
		"statusBar.background": "#2b2b2b",
		"statusBar.foreground": "#9a9794",
		"statusBar.noFolderBackground": "#2b2b2b",
		"statusBar.debuggingBackground": "#d8996e",
		"statusBar.debuggingForeground": "#ffffff",
		"statusBarItem.remoteBackground": "#6ed8aa",
		"titleBar.activeBackground": "#2b2b2b",
		"titleBar.activeForeground": "#c8c6c5",
		"titleBar.inactiveBackground": "#2b2b2b",
		"titleBar.inactiveForeground": "#7a7775",
		"panel.background": "#383838",
		"panel.border": "#242424",
		"panelTitle.activeForeground": "#c8c6c5",
		"panelTitle.inactiveForeground": "#7a7775",
		"terminal.background": "#242424",
		"terminal.foreground": "#c8c6c5",
		"terminal.ansiBlack": "#1a1a1a",
		"terminal.ansiRed": "#d86e6e",
		"terminal.ansiGreen": "#6ed8aa",
		"terminal.ansiYellow": "#d8b56e",
		"terminal.ansiBlue": "#6ea3d8",
		"terminal.ansiMagenta": "#9e6ed8",
		"terminal.ansiCyan": "#6eced8",
		"terminal.ansiWhite": "#c8c6c5",
		"terminal.ansiBrightBlack": "#7a7775",
		"terminal.ansiBrightRed": "#e87d7d",
		"terminal.ansiBrightGreen": "#82e3b9",
		"terminal.ansiBrightYellow": "#e8c47d",
		"terminal.ansiBrightBlue": "#86b8ea",
		"terminal.ansiBrightMagenta": "#ea86b8",
		"terminal.ansiBrightCyan": "#8adce5",
		"terminal.ansiBrightWhite": "#ffffff",
		"input.background": "#303030",
		"input.border": "#575757",
		"input.foreground": "#c8c6c5",
		"dropdown.background": "#303030",
		"dropdown.border": "#575757",
		"button.background": "#6ed8aa",
		"button.foreground": "#1a2410",
		"button.hoverBackground": "#56d29c",
		"badge.background": "#6ea3d8",
		"badge.foreground": "#ffffff",
		"scrollbarSlider.background": "#ffffff1a",
		"scrollbarSlider.hoverBackground": "#ffffff2a",
		"scrollbarSlider.activeBackground": "#ffffff3a",
		"progressBar.background": "#d8996e",
		"breadcrumb.foreground": "#9a9794",
		"breadcrumb.focusForeground": "#c8c6c5",
		"gitDecoration.modifiedResourceForeground": "#d8996e",
		"gitDecoration.addedResourceForeground": "#6ed8aa",
		"gitDecoration.deletedResourceForeground": "#d86e6e",
		"gitDecoration.untrackedResourceForeground": "#6ed8aa",
		"gitDecoration.ignoredResourceForeground": "#7a7775",
		"gitDecoration.conflictingResourceForeground": "#9e6ed8",
		"peekView.border": "#6ea3d8",
		"textLink.foreground": "#6ea3d8",
		"textLink.activeForeground": "#92bde7"
	},
	"tokenColors": [
		{
			"settings": {}
		},
		{
			"scope": "comment, punctuation.definition.comment",
			"settings": {
				"foreground": "#7a7775",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "string, string.quoted, string.template, meta.string",
			"settings": {
				"foreground": "#6ed8aa"
			}
		},
		{
			"scope": "constant.character.escape, constant.other.placeholder, string.regexp constant.character.escape",
			"settings": {
				"foreground": "#9e6ed8"
			}
		},
		{
			"scope": "string.regexp, keyword.operator.regexp",
			"settings": {
				"foreground": "#d8996e"
			}
		},
		{
			"scope": "constant.numeric, constant.numeric.integer, constant.numeric.float, keyword.other.unit",
			"settings": {
				"foreground": "#9e6ed8"
			}
		},
		{
			"scope": "constant.language, constant.language.boolean, constant.language.null, constant.language.undefined",
			"settings": {
				"foreground": "#d8996e"
			}
		},
		{
			"scope": "constant.other, support.constant, constant.other.color",
			"settings": {
				"foreground": "#d8996e"
			}
		},
		{
			"scope": "keyword, keyword.control, keyword.other, keyword.declaration",
			"settings": {
				"foreground": "#d86ea3"
			}
		},
		{
			"scope": "keyword.operator, keyword.operator.new, keyword.operator.expression, punctuation.accessor",
			"settings": {
				"foreground": "#d86ea3"
			}
		},
		{
			"scope": "storage, storage.type, storage.modifier",
			"settings": {
				"foreground": "#d86ea3"
			}
		},
		{
			"scope": "entity.name.function, support.function, meta.function-call entity.name.function, variable.function",
			"settings": {
				"foreground": "#6ea3d8"
			}
		},
		{
			"scope": "entity.name.class, entity.name.type, entity.name.namespace, support.type, support.class, entity.other.inherited-class, entity.name.type.class",
			"settings": {
				"foreground": "#d8b56e"
			}
		},
		{
			"scope": "entity.name.tag, punctuation.definition.tag",
			"settings": {
				"foreground": "#d86ea3"
			}
		},
		{
			"scope": "entity.other.attribute-name, entity.other.attribute-name.html, entity.other.attribute-name.class.css",
			"settings": {
				"foreground": "#6ed8aa"
			}
		},
		{
			"scope": "support.type.property-name, meta.object-literal.key, support.type.property-name.json, support.type.property-name.css, entity.name.tag.yaml",
			"settings": {
				"foreground": "#6ea3d8"
			}
		},
		{
			"scope": "variable, variable.other, variable.other.readwrite, meta.definition.variable",
			"settings": {
				"foreground": "#c8c6c5"
			}
		},
		{
			"scope": "variable.other.constant, variable.other.enummember",
			"settings": {
				"foreground": "#d8996e"
			}
		},
		{
			"scope": "variable.parameter, meta.function.parameters",
			"settings": {
				"foreground": "#d8996e",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "variable.language, variable.language.this, variable.language.self, variable.language.super",
			"settings": {
				"foreground": "#d8996e",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "entity.name.function.decorator, meta.decorator, punctuation.decorator, meta.annotation, storage.type.annotation",
			"settings": {
				"foreground": "#d8b56e"
			}
		},
		{
			"scope": "punctuation, meta.brace, punctuation.separator, punctuation.terminator, punctuation.definition.parameters",
			"settings": {
				"foreground": "#9a9794"
			}
		},
		{
			"scope": "entity.name.label, support.other.namespace",
			"settings": {
				"foreground": "#d8b56e"
			}
		},
		{
			"scope": "markup.heading, markup.heading entity.name, entity.name.section",
			"settings": {
				"foreground": "#6ea3d8",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.bold",
			"settings": {
				"foreground": "#d8996e",
				"fontStyle": "bold"
			}
		},
		{
			"scope": "markup.italic",
			"settings": {
				"foreground": "#c8c6c5",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.underline.link, markup.link, string.other.link, constant.other.reference.link",
			"settings": {
				"foreground": "#6ea3d8",
				"fontStyle": "underline"
			}
		},
		{
			"scope": "markup.inline.raw, markup.raw, markup.fenced_code",
			"settings": {
				"foreground": "#6ed8aa"
			}
		},
		{
			"scope": "markup.quote",
			"settings": {
				"foreground": "#9a9794",
				"fontStyle": "italic"
			}
		},
		{
			"scope": "markup.list punctuation.definition.list.begin",
			"settings": {
				"foreground": "#d86ea3"
			}
		},
		{
			"scope": "markup.inserted, markup.inserted.diff, meta.diff.header.to-file",
			"settings": {
				"foreground": "#6ed8aa"
			}
		},
		{
			"scope": "markup.deleted, markup.deleted.diff, meta.diff.header.from-file",
			"settings": {
				"foreground": "#d86e6e"
			}
		},
		{
			"scope": "markup.changed, markup.changed.diff",
			"settings": {
				"foreground": "#d8b56e"
			}
		},
		{
			"scope": "meta.diff.range, punctuation.definition.range.diff",
			"settings": {
				"foreground": "#9e6ed8"
			}
		},
		{
			"scope": "invalid, invalid.illegal",
			"settings": {
				"foreground": "#d86e6e"
			}
		},
		{
			"scope": "invalid.deprecated",
			"settings": {
				"foreground": "#d8996e"
			}
		}
	]
}

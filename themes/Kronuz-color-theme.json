{
	"name": "Kronuz",
	"type": "dark",
	"semanticHighlighting": true,
	"colors": {
		"focusBorder": "#cc783380",
		"foreground": "#c8c6c5",
		"selection.background": "#3366ff55",
		"editor.background": "#383838",
		"editor.foreground": "#c8c6c5",
		"editorCursor.foreground": "#d08040",
		"editor.selectionBackground": "#3366ff55",
		"editor.selectionHighlightBackground": "#6089b422",
		"editor.wordHighlightBackground": "#6089b420",
		"editor.wordHighlightStrongBackground": "#d0d0ff26",
		"editor.findMatchBackground": "#cc783355",
		"editor.findMatchHighlightBackground": "#cc783333",
		"editor.lineHighlightBackground": "#ffffff0a",
		"editor.rangeHighlightBackground": "#6089b414",
		"editorLineNumber.foreground": "#7a7775",
		"editorLineNumber.activeForeground": "#c8c6c5",
		"editorIndentGuide.background": "#ffffff10",
